{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Public user profile information accessible to other users.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "Display name or pseudo" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "birthDate": { "type": "string", "format": "date-time" },
        "city": { "type": "string" },
        "bio": { "type": "string", "description": "Self-description" },
        "lookingFor": { "type": "string", "enum": ["serious", "friendship", "casual"] },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "type": "string" }, "description": "URLs of profile photos" },
        "mainPhoto": { "type": "string", "description": "Primary profile photo URL" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" },
        "isVerified": { "type": "boolean" },
        "isBanned": { "type": "boolean" }
      },
      "required": ["displayName", "gender", "birthDate", "city"]
    },
    "PrivateInfo": {
      "title": "Private User Info",
      "description": "Sensitive user data accessible only to the owner.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "Private message between two users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "content", "timestamp"]
    },
    "Like": {
      "title": "Interest",
      "description": "A 'like' from one user to another.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Mutual interest between two users.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "IDs of the two users" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification for events like likes, matches, or messages.",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "match", "message"] },
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "content": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "type", "fromId", "timestamp"]
    },
    "View": {
      "title": "View",
      "description": "Records when a user views another user's profile.",
      "type": "object",
      "properties": {
        "viewerId": { "type": "string" },
        "profileId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["viewerId", "profileId", "timestamp"]
    },
    "Review": {
      "title": "Review",
      "description": "User reviews or messages of encouragement/feedback.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "targetId": { "type": "string" },
        "content": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "targetId", "content", "timestamp"]
    },
    "Story": {
      "title": "Story",
      "description": "A temporary status update or story posted by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "timestamp"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "User moderation interaction (report, block).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["report", "block"] },
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "fromId", "toId", "timestamp"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global application settings controlled by admins.",
      "type": "object",
      "properties": {
        "broadcast": { "type": "string", "description": "Global message content" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/config": {
      "schema": "AdminSettings",
      "description": "Global app configuration"
    },
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "Public profiles"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "User status stories"
    },
    "/users/{userId}/private/info": {
      "schema": "PrivateInfo",
      "description": "Sensitive user data"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Private messages in a chat"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "User likes"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Mutual matches"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/views/{viewId}": {
      "schema": "View",
      "description": "Profile views"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "User moderation interactions like signal or block"
    }
  }
}
